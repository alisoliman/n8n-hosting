# Azure Tenant ID
# Find your tenant ID: https://learn.microsoft.com/en-us/azure/active-directory/fundamentals/active-directory-how-to-find-tenant
TENANT_ID=your-tenant-id

# Fabric Data Agent URL
# This is the published URL of your Fabric Data Agent
# Example: https://api.fabric.microsoft.com/v1/workspaces/{workspace-id}/dataagents/{agent-id}
DATA_AGENT_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/aiskills/<skill-id>/aiassistant/openai
